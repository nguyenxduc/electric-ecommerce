# Database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/DBNAME?schema=public"

# User behavior: số ngày giữ event thô (job prune). Tối thiểu 7, mặc định trong code = 90 nếu không set.
USER_BEHAVIOR_RETENTION_DAYS=90

# Rollup daily: ngày UTC dạng YYYY-MM-DD (tuỳ chọn). Không set = hôm qua UTC.
# USER_BEHAVIOR_ROLLUP_DAY=2025-03-28

# JWT / app
ACCESS_TOKEN_SECRET=change-me
FRONTEND_URL=http://localhost:5173
DAILY_JOBS_ENABLED=true
DAILY_JOBS_RUN_ON_START=true
DAILY_JOBS_INTERVAL_HOURS=24

# Idempotent tasks started in the background when the backend starts.
AUTO_SETUP_SIMILARITY=true
AUTO_EMBED_PRODUCTS=true

# Google AI Studio — https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Chat: compare, assistant, review moderation, image search
GEMINI_CHAT_MODEL=gemini-3.1-flash-lite
GEMINI_MODEL=gemini-3.1-flash-lite
# Embeddings for product search / RAG
GEMINI_EMBED_MODEL=gemini-embedding-001
# Upload-image detect (vision) — must be a Gemini multimodal model, not Gemma
IMAGE_SEARCH_MODEL=gemini-3.1-flash-lite
# Optional fallback if primary is rate-limited (e.g. gemini-2.5-flash)
IMAGE_SEARCH_FALLBACK_MODEL=
# Store currency (USD) — shipping & free-ship threshold in seed/settings
SHIPPING_FEE=9.99
FREE_SHIPPING_THRESHOLD=199
# VN payment gateways (MoMo/VNPay) convert USD checkout total → VND
USD_TO_VND_RATE=25000
# MoMo sandbox minimum charge (VND)
MOMO_MIN_AMOUNT_VND=1000

# Optional HTTP proxy for Google API (some networks)
# AI_HTTP_PROXY=
